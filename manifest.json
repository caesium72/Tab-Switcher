{
  "manifest_version": 3,
  "name": "Keyboard Tab Switcher",
  "version": "1.0",
  "description": "Switch tabs using keyboard shortcuts.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Keyboard Tab Switcher - Click to configure shortcuts"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "next-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+Right",
        "mac": "Command+Shift+Right"
      },
      "description": "Switch to the next tab"
    },
    "prev-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+Left",
        "mac": "Command+Shift+Left"
      },
      "description": "Switch to the previous tab"
    }
  }
}
